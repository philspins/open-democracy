package templates

import (
	"fmt"
	"github.com/philspins/open-democracy/internal/store"
)

templ BillDetail(ps store.ParliamentStatus, bill store.BillRow, stages []store.BillStageRow, divs []store.DivisionRow, reactions store.BillReactionCounts) {
	@Layout(bill.Number+" — "+ShortOrFullTitle(bill), ps) {
		<div class="space-y-6">
			<!-- Header -->
			<div>
				<div class="flex items-center gap-2 mb-2">
					<a href="/bills" class="text-sm text-blue-600 hover:underline">← Bills</a>
				</div>
				<div class="flex items-start gap-3">
					<span class="font-mono font-bold text-2xl text-blue-700">{ bill.Number }</span>
					if bill.Category != "" {
						<span class="mt-1 text-sm px-2 py-0.5 rounded-full text-white" style={ CategoryBadgeStyle(bill.Category) }>{ bill.Category }</span>
					}
				</div>
				<h1 class="text-xl font-semibold text-gray-900 mt-2">{ bill.Title }</h1>
				if bill.ShortTitle != "" && bill.ShortTitle != bill.Title {
					<p class="text-gray-600 italic mt-1">{ bill.ShortTitle }</p>
				}
			</div>

			<!-- Meta grid -->
			<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 bg-gray-50 rounded-lg p-4">
				<div>
					<p class="text-xs text-gray-500">Chamber</p>
					<p class="font-medium capitalize">{ bill.Chamber }</p>
				</div>
				<div>
					<p class="text-xs text-gray-500">Stage</p>
					<p class="font-medium">{ StageLabel(bill.CurrentStage) }</p>
				</div>
				if bill.SponsorName != "" {
					<div>
						<p class="text-xs text-gray-500">Sponsor</p>
						<p class="font-medium">
							if bill.SponsorID != "" {
								<a href={ templ.SafeURL("/members/" + bill.SponsorID) } class="text-blue-600 hover:underline">{ bill.SponsorName }</a>
							} else {
								{ bill.SponsorName }
							}
						</p>
					</div>
				}
				<div>
					<p class="text-xs text-gray-500">Introduced</p>
					<p class="font-medium">{ FormatDate(bill.IntroducedDate) }</p>
				</div>
			</div>

			<!-- Stage progress bar (same widget as the bills list) -->
			if bill.CurrentStage != "" {
				<section>
					<h2 class="text-lg font-semibold text-gray-800 mb-3">Progress</h2>
					@stageProgress(bill.CurrentStage)
				</section>
			}

			<!-- Summaries -->
			if bill.SummaryLoP != "" {
				<section>
					<h2 class="text-lg font-semibold text-gray-800 mb-3">Summary</h2>
					<div class="grid sm:grid-cols-2 gap-4">
						<div class="bg-blue-50 rounded-lg p-4">
							<p class="text-xs font-semibold text-blue-700 uppercase tracking-wide mb-2">Library of Parliament</p>
							<p class="text-sm text-gray-700">{ bill.SummaryLoP }</p>
						</div>
					</div>
					<p class="text-xs text-gray-400 mt-2">Source: Library of Parliament</p>
				</section>
			} else if bill.SummaryAI != "" {
				{{ aiSummary := ParseAISummary(bill.SummaryAI) }}
				<section>
					<h2 class="text-lg font-semibold text-gray-800 mb-3">
						Summary
						<span class="text-xs font-normal text-gray-400">(AI-generated)</span>
					</h2>
					if aiSummary.OneSentence != "" {
						<div class="bg-yellow-50 border-l-4 border-yellow-400 rounded-r-lg p-4 mb-4">
							<p class="font-medium text-gray-800">{ aiSummary.OneSentence }</p>
						</div>
					}
					<div class="grid sm:grid-cols-2 gap-4">
						<!-- Left column: plain summary -->
						if aiSummary.PlainSummary != "" {
							<div class="bg-gray-50 rounded-lg p-4">
								<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Overview</p>
								<p class="text-sm text-gray-700">{ aiSummary.PlainSummary }</p>
								if aiSummary.EstimatedCost != "" {
									<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mt-3 mb-1">Estimated Cost</p>
									<p class="text-sm text-gray-700">{ aiSummary.EstimatedCost }</p>
								}
							</div>
						}
						<!-- Right column: lists -->
						<div class="space-y-3">
							if len(aiSummary.KeyChanges) > 0 {
								<div class="bg-gray-50 rounded-lg p-4">
									<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Key Changes</p>
									<ul class="list-disc list-inside space-y-1">
										for _, item := range aiSummary.KeyChanges {
											<li class="text-sm text-gray-700">{ item }</li>
										}
									</ul>
								</div>
							}
							if len(aiSummary.WhoIsAffected) > 0 {
								<div class="bg-gray-50 rounded-lg p-4">
									<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Who&#39;s Affected</p>
									<ul class="list-disc list-inside space-y-1">
										for _, item := range aiSummary.WhoIsAffected {
											<li class="text-sm text-gray-700">{ item }</li>
										}
									</ul>
								</div>
							}
							if len(aiSummary.NotableConsiderations) > 0 {
								<div class="bg-gray-50 rounded-lg p-4">
									<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Notable Considerations</p>
									<ul class="list-disc list-inside space-y-1">
										for _, item := range aiSummary.NotableConsiderations {
											<li class="text-sm text-gray-700">{ item }</li>
										}
									</ul>
								</div>
							}
						</div>
					</div>
					<p class="text-xs text-gray-400 mt-2">Automatically generated from bill text using Claude</p>
				</section>
			}

			<!-- External links -->
			<div class="flex gap-4">
				if bill.LegisInfoURL != "" {
					<a href={ templ.SafeURL(bill.LegisInfoURL) } target="_blank" rel="noopener"
					   class="text-sm text-blue-600 hover:underline">LEGISinfo →</a>
				}
				if bill.FullTextURL != "" {
					<a href={ templ.SafeURL(bill.FullTextURL) } target="_blank" rel="noopener"
					   class="text-sm text-blue-600 hover:underline">Full Text →</a>
				}
			</div>

			<!-- Constituent sentiment -->
			<section class="bg-white rounded-lg border border-gray-200 p-4">
				<h2 class="text-lg font-semibold text-gray-800 mb-3">Constituent Sentiment</h2>
				<div class="grid sm:grid-cols-2 gap-6 items-center">
					<!-- Pie chart -->
					<div class="flex flex-col items-center gap-2">
						@templ.Raw(ReactionPieChartSVG(reactions.SupportCount, reactions.OpposeCount, reactions.NeutralCount, reactions.TotalReactions))
						<p class="text-xs text-gray-500">{ fmt.Sprint(reactions.TotalReactions) } total responses</p>
					</div>
					<!-- Legend & reaction buttons -->
					<div class="space-y-4">
						<!-- Counts -->
						<div class="space-y-1 text-sm">
							<div class="flex items-center gap-2">
								<span class="inline-block w-3 h-3 rounded-full bg-green-500"></span>
								<span class="text-gray-700">Support</span>
								<span class="ml-auto font-medium text-gray-800">{ fmt.Sprint(reactions.SupportCount) }</span>
							</div>
							<div class="flex items-center gap-2">
								<span class="inline-block w-3 h-3 rounded-full bg-red-500"></span>
								<span class="text-gray-700">Oppose</span>
								<span class="ml-auto font-medium text-gray-800">{ fmt.Sprint(reactions.OpposeCount) }</span>
							</div>
							<div class="flex items-center gap-2">
								<span class="inline-block w-3 h-3 rounded-full bg-gray-400"></span>
								<span class="text-gray-700">Neutral</span>
								<span class="ml-auto font-medium text-gray-800">{ fmt.Sprint(reactions.NeutralCount) }</span>
							</div>
						</div>
						<!-- Icon buttons — each auto-submits on click -->
						<div class="flex items-center gap-3 pt-3 border-t border-gray-100">
							<form method="POST" action="/api/react" class="inline">
								<input type="hidden" name="bill_id" value={ bill.ID }/>
								<input type="hidden" name="reaction" value="support"/>
								<button type="submit" title="Support" class="text-2xl hover:scale-110 transition-transform" aria-label="Support this bill">👍</button>
							</form>
							<form method="POST" action="/api/react" class="inline">
								<input type="hidden" name="bill_id" value={ bill.ID }/>
								<input type="hidden" name="reaction" value="neutral"/>
								<button type="submit" title="Neutral" class="text-2xl hover:scale-110 transition-transform" aria-label="Neutral on this bill">🤔</button>
							</form>
							<form method="POST" action="/api/react" class="inline">
								<input type="hidden" name="bill_id" value={ bill.ID }/>
								<input type="hidden" name="reaction" value="oppose"/>
								<button type="submit" title="Oppose" class="text-2xl hover:scale-110 transition-transform" aria-label="Oppose this bill">👎</button>
							</form>
						</div>
					</div>
				</div>
			</section>

			<!-- Divisions -->
			if len(divs) > 0 {
				<section>
					<h2 class="text-lg font-semibold text-gray-800 mb-3">Recorded Votes</h2>
					<div class="overflow-x-auto">
						<table class="min-w-full text-sm">
							<thead>
								<tr class="bg-gray-50 text-left text-xs text-gray-500">
									<th class="px-3 py-2">Date</th>
									<th class="px-3 py-2">Description</th>
									<th class="px-3 py-2 text-right">Yeas</th>
									<th class="px-3 py-2 text-right">Nays</th>
									<th class="px-3 py-2">Result</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-gray-100">
								for _, d := range divs {
									<tr class="hover:bg-gray-50">
										<td class="px-3 py-2 text-gray-500 whitespace-nowrap">{ FormatDate(d.Date) }</td>
										<td class="px-3 py-2">{ d.Description }</td>
										<td class="px-3 py-2 text-right text-green-600 font-medium">{ fmt.Sprint(d.Yeas) }</td>
										<td class="px-3 py-2 text-right text-red-600 font-medium">{ fmt.Sprint(d.Nays) }</td>
										<td class="px-3 py-2 text-gray-600">{ d.Result }</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</section>
			}
		</div>
	}
}
